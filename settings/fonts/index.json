{
  "systemName": "QUANT-X Typography Configuration",
  "version": "1.0.0",
  "theme": "Terminal Dark",
  "defaultFontFamily": "mono",
  "fonts": {
    "mono": {
      "name": "JetBrains Mono",
      "provider": "Google Fonts",
      "importUrl": "https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;700;800&display=swap",
      "fallback": ["ui-monospace", "SFMono-Regular", "Menlo", "Monaco", "Consolas", "monospace"],
      "description": "Designed for maximum code readability and clean column alignment in tabular grids."
    },
    "verdana": {
      "name": "Verdana",
      "provider": "System Native",
      "fallback": ["Geneva", "sans-serif"],
      "description": "Used primarily in database matrices and lists where readability is highly prioritized."
    }
  },
  "sizes": {
    "root": "16px",
    "scale": {
      "micro": {
        "css": "text-[8px]",
        "rem": "0.5rem",
        "px": "8px",
        "usage": "Data labels, secondary column headings, indicator tags"
      },
      "xs-secondary": {
        "css": "text-[9px]",
        "rem": "0.5625rem",
        "px": "9px",
        "usage": "Telemetry logs, timestamp streams, secondary values"
      },
      "xs": {
        "css": "text-xs",
        "rem": "0.75rem",
        "px": "12px",
        "usage": "Table headers, search input fields, primary data metrics"
      },
      "sm": {
        "css": "text-sm",
        "rem": "0.875rem",
        "px": "14px",
        "usage": "Category titles, form selections, button labels"
      },
      "base": {
        "css": "text-base",
        "rem": "1rem",
        "px": "16px",
        "usage": "Diagnostic headings, status boxes"
      },
      "lg": {
        "css": "text-lg",
        "rem": "1.125rem",
        "px": "18px",
        "usage": "Primary control labels, modal headings"
      },
      "xl-header": {
        "css": "text-2xl",
        "rem": "1.5rem",
        "px": "24px",
        "usage": "Primary screen titles, active symbol valuation metrics"
      }
    }
  },
  "weights": {
    "light": {
      "css": "font-light",
      "value": "300"
    },
    "normal": {
      "css": "font-normal",
      "value": "400"
    },
    "medium": {
      "css": "font-medium",
      "value": "500"
    },
    "bold": {
      "css": "font-bold",
      "value": "700"
    },
    "black": {
      "css": "font-black",
      "value": "800"
    }
  },
  "spacing": {
    "letterSpacing": {
      "tighter": "-0.05em",
      "tight": "-0.025em",
      "normal": "0em",
      "wide": "0.025em",
      "wider": "0.05em",
      "widest": "0.1em"
    },
    "lineHeight": {
      "none": "1",
      "tight": "1.25",
      "snug": "1.375",
      "normal": "1.5",
      "relaxed": "1.625"
    }
  }
}